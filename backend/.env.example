# LeadKeeper - Email Configuration Example
# Copy this file to .env and fill in your values

# ==========================================
# OWNER SETTINGS
# ==========================================
# Email address where notifications about new leads will be sent
OWNER_EMAIL=test@d9911.org

# ==========================================
# SMTP CONFIGURATION (Primary)
# ==========================================
SMTP_HOST=smtp.mail.ru
SMTP_USER=d.9911@mail.ru
SMTP_PASS=your_password_here
SMTP_PORT=465
SMTP_SECURE=true

# ==========================================
# SMTP CONFIGURATION (Secondary / Fallback)
# ==========================================
SMTP_HOST_2=sandbox.smtp.mailtrap.io
SMTP_USER_2=user_name
SMTP_PASS_2=password
SMTP_PORT_2=2525
SMTP_SECURE_2=false

# ==========================================
# SMTP METHOD
# ==========================================
# 0 = Email notifications disabled
# 1 = Use primary SMTP server
# 2 = Use secondary SMTP server
SMTP_METHOD=1

# ==========================================
# OPTIONAL: Custom FROM address
# ==========================================
# SMTP_FROM_NAME=LeadKeeper
# SMTP_FROM_EMAIL=no-reply@example.com